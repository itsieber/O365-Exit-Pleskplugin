<?php echo $this->renderTabs($this->tabs); ?>

<h2>Postfächer: <?php echo htmlspecialchars($this->domain->getName()); ?></h2>

<?php if (empty($this->o365mailboxes)): ?>
    <p style="color:#c00">Keine O365-Postfächer gefunden. Bitte prüfen Sie die Azure AD Berechtigungen (User.Read.All).</p>
<?php else: ?>
    <p><?php echo count($this->o365mailboxes); ?> O365-Postfächer gefunden. Wählen Sie das Ziel-Postfach und starten Sie die Migration.</p>

    <table class="list" style="width:100%">
        <thead>
            <tr>
                <th>O365 Postfach</th>
                <th>Name</th>
                <th>Plesk Ziel-Postfach</th>
                <th>Ab Datum</th>
                <th>Aktion</th>
            </tr>
        </thead>
        <tbody>
        <?php foreach ($this->o365mailboxes as $i => $mb): ?>
            <tr>
                <td><?php echo htmlspecialchars($mb['email']); ?></td>
                <td><?php echo htmlspecialchars($mb['display_name']); ?></td>
                <td>
                    <select id="plesk_<?php echo $i; ?>" style="min-width:200px">
                        <option value="">-- Postfach wählen --</option>
                        <?php foreach ($this->localMailboxes as $addr => $label): ?>
                            <?php $selected = (strtolower($addr) === strtolower($mb['email'])) ? 'selected' : ''; ?>
                            <option value="<?php echo htmlspecialchars($addr); ?>" <?php echo $selected; ?>>
                                <?php echo htmlspecialchars($label); ?>
                            </option>
                        <?php endforeach; ?>
                    </select>
                </td>
                <td>
                    <input type="date" id="date_<?php echo $i; ?>" style="width:130px">
                </td>
                <td>
                    <button type="button" class="btn btn-primary"
                            onclick="startMigration(
                                '<?php echo htmlspecialchars($this->domainId); ?>',
                                '<?php echo htmlspecialchars(addslashes($mb['email'])); ?>',
                                document.getElementById('plesk_<?php echo $i; ?>').value,
                                document.getElementById('date_<?php echo $i; ?>').value,
                                document.getElementById('fullsync_<?php echo $i; ?>').checked ? '1' : '0'
                            )">
                        Migrieren
                    </button>
                    <label style="margin-left:8px;font-size:0.85em;white-space:nowrap">
                        <input type="checkbox" id="fullsync_<?php echo $i; ?>">
                        Vollsync
                    </label>
                </td>
            </tr>
        <?php endforeach; ?>
        </tbody>
    </table>

    <form id="migrateForm" method="post" action="<?php echo $this->migrateUrl; ?>" style="display:none">
        <input type="hidden" name="domain_id"   id="f_domain_id">
        <input type="hidden" name="o365_email"  id="f_o365_email">
        <input type="hidden" name="plesk_email" id="f_plesk_email">
        <input type="hidden" name="date_from"   id="f_date_from">
        <input type="hidden" name="fullsync"    id="f_fullsync" value="0">
    </form>

    <script>
    function startMigration(domainId, o365Email, pleskEmail, dateFrom, fullsync) {
        if (!pleskEmail) { alert('Bitte ein Ziel-Postfach auswählen.'); return; }
        if (!confirm('Migration starten für ' + o365Email + ' → ' + pleskEmail + '?')) return;
        document.getElementById('f_domain_id').value   = domainId;
        document.getElementById('f_o365_email').value  = o365Email;
        document.getElementById('f_plesk_email').value = pleskEmail;
        document.getElementById('f_date_from').value   = dateFrom;
        document.getElementById('f_fullsync').value    = fullsync;
        document.getElementById('migrateForm').submit();
    }
    </script>
<?php endif; ?>
